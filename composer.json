{
    "name": "infomediji/fluent-table",
    "description": "Fluent PHP builder for Tabler UI data tables with REST endpoint support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-strict-rules": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Infomediji\\FluentTable\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}